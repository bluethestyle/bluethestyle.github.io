---
import "../styles/site.css";
import { SITE, RECENT, TAGS, POSTS, CATEGORIES, SERIES } from "../data.js";
import { getCollection } from "astro:content";
const { title = "bluethestyle", tab = "home" } = Astro.props;
const trendingTags = [...TAGS].sort((a, b) => b.count - a.count).slice(0, 9);
const publishedCount = POSTS.filter(p => !p.draft).length;
const lastDate = [...POSTS].filter(p => !p.draft).sort((a, b) => b.date.localeCompare(a.date))[0]?.date;
const lastLabel = lastDate
  ? new Date(lastDate).toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" }).toLowerCase()
  : "";

// Dynamic ep count: unique part numbers per series (language-agnostic, drafts excluded)
const allPosts = await getCollection("posts");
const seriesEpCount = {};
for (const p of allPosts) {
  const key = p.data.series;
  if (!key || typeof p.data.part !== "number") continue;
  if (!seriesEpCount[key]) seriesEpCount[key] = new Set();
  seriesEpCount[key].add(p.data.part);
}
const seriesCurrent = Object.fromEntries(
  Object.entries(seriesEpCount).map(([k, v]) => [k, v.size]),
);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;1,9..144,400&family=Inter+Tight:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/gh/sun-typeface/SUIT@2/fonts/variable/woff2/SUIT-Variable.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" integrity="sha384-nB0miv6/jRmo5UMMR1wu3Gz6NLsoTkbqJghGIsx//Rlm+ZU03BU6SQNC66uf4l5+" crossorigin="anonymous" />
    <script
      data-goatcounter="https://bluethestyle.goatcounter.com/count"
      async
      src="//gc.zgo.at/count.js"
    ></script>
    <style is:global>
      :root { --display: "Fraunces", Georgia, serif; --sans: "Inter Tight", -apple-system, sans-serif; --mono: "JetBrains Mono", monospace; --kr: "SUIT Variable", -apple-system, sans-serif; }
    </style>
  </head>
  <body data-theme="paper">
    <div class="frame">
      <!-- topbar -->
      <div class="topbar">
        <a href="/" class="logo"><span class="dot"></span>bluethestyle<span class="sub">/ field notes</span></a>
        <div class="tabs">
          <a href="/" class={tab === "home" ? "on" : ""}>HOME</a>
          <a href="/categories/" class={tab === "categories" ? "on" : ""}>CATEGORIES <span class="n">04</span></a>
          <a href="/tags/" class={tab === "tags" ? "on" : ""}>TAGS <span class="n">09</span></a>
          <a href="/archives/" class={tab === "archives" ? "on" : ""}>ARCHIVES <span class="n">06</span></a>
        </div>
        <div class="tb-tools">
          <div class="status"><span class="live"></span>writing</div>
          <div class="search"><input placeholder="search…" /><span class="kbd">⌘K</span></div>
          <div class="lang-sw"><button class="on">EN</button><button>한</button></div>
        </div>
      </div>
      <!-- sidebar-l -->
      <aside class="sidebar-l">
        <div class="bio-card">
          <div class="avatar"></div>
          <div class="who">Seonkyu Jeong</div>
          <div class="role"><b>Independent researcher</b><br/>financial AI · MRM · agents<br/>GARP FRM · Seoul</div>
        </div>

        <div class="nav-label">Navigate</div>
        <ul class="nav-list">
          <li><a href="/" class={tab === "home" ? "on" : ""}><span class="nav-inner"><span class="num">01</span><span class="lbl">HOME</span></span></a></li>
          <li><a href="/categories/" class={tab === "categories" ? "on" : ""}><span class="nav-inner"><span class="num">02</span><span class="lbl">CATEGORIES</span></span><span class="n">{CATEGORIES.length}</span></a></li>
          <li><a href="/tags/" class={tab === "tags" ? "on" : ""}><span class="nav-inner"><span class="num">03</span><span class="lbl">TAGS</span></span><span class="n">{TAGS.length}</span></a></li>
          <li><a href="/archives/" class={tab === "archives" ? "on" : ""}><span class="nav-inner"><span class="num">04</span><span class="lbl">ARCHIVES</span></span><span class="n">{publishedCount}</span></a></li>
        </ul>

        <div class="nav-label">Elsewhere</div>
        <div class="socials">
          <a href="mailto:jsk320098@gmail.com"><span>Email</span><span class="arr">↗</span></a>
          <a href="https://github.com/bluethestyle" rel="me"><span>GitHub</span><span class="arr">↗</span></a>
          <a href={`https://orcid.org/${SITE.orcid}`} rel="me"><span>ORCID</span><span class="arr">↗</span></a>
          <a href="https://zenodo.org/communities/bluethestyle" rel="me"><span>Zenodo</span><span class="arr">↗</span></a>
        </div>

        <div class="nav-label">Series · active</div>
        <div class="series-mini">
          {SERIES.map((s) => {
            const n = seriesCurrent[s.slug] ?? s.ep;
            return (
              <a href={s.en} class="series-row">
                <span class="cat">[{s.tag}]</span>
                <span class="prog">ep {n}{s.total ? `/${s.total}` : ""}</span>
              </a>
            );
          })}
        </div>

        <div class="kv">
          <div><span class="k">build</span>idx.2026.04</div>
          <div><span class="k">stack</span>astro · react</div>
          <div><span class="k">last</span>{lastLabel}</div>
          <div><span class="k">posts</span>{publishedCount}</div>
          <div><span class="k">lic</span>cc by-nc 4.0</div>
        </div>
      </aside>
      <!-- main -->
      <main class="main"><slot /></main>
      <!-- sidebar-r -->
      <aside class="sidebar-r">
        <div class="widget">
          <div class="w-head"><h3>Index</h3><span class="n">live</span></div>
          <div class="stats">
            <div class="stat"><div class="v">{publishedCount}</div><div class="l">posts</div></div>
            <div class="stat"><div class="v">{CATEGORIES.length}</div><div class="l">categories</div></div>
            <div class="stat"><div class="v">{TAGS.length}</div><div class="l">tags</div></div>
            <div class="stat"><div class="v">{SITE.counts.years}</div><div class="l">years</div></div>
          </div>
        </div>

        <div class="widget">
          <div class="w-head"><h3>Recently updated</h3><span class="n">{RECENT.length}</span></div>
          <div class="recent">
            {RECENT.map((r) => {
              const isKo = /[\uac00-\ud7af]/.test(r.title);
              return (
                <a href={r.url || "#"}>
                  <div class="r-top">
                    <span>today</span>
                    <span>{r.date}</span>
                  </div>
                  <div class={"r-t" + (isKo ? " kr" : "")}>
                    {r.title}
                    <span class="arr">↗</span>
                  </div>
                </a>
              );
            })}
          </div>
        </div>

        <div class="widget">
          <div class="w-head"><h3>Trending tags</h3><span class="n">{TAGS.length}</span></div>
          <div class="tags-w">
            {trendingTags.map((t) => (
              <a class={"tag-pill" + (t.hot ? " hot" : "")} href={`/tags/#${t.slug}`}>
                #{t.name}<span class="c">{t.count}</span>
              </a>
            ))}
          </div>
        </div>

        <div class="widget">
          <div class="w-head"><h3>ORCID</h3></div>
          <div class="orcid">
            <div class="hdr">Verified researcher</div>
            <div class="id">{SITE.orcid}</div>
            <a class="link" href={`https://orcid.org/${SITE.orcid}`} rel="me">orcid.org ↗</a>
          </div>
        </div>

        <div class="widget">
          <div class="w-head"><h3>Colophon</h3></div>
          <div class="kv">
            <div><span class="k">theme</span>paper · ink · warm · vellum</div>
            <div><span class="k">engine</span>astro · react</div>
            <div><span class="k">host</span>github pages</div>
            <div><span class="k">©</span>2026 {SITE.owner}</div>
          </div>
        </div>
      </aside>
    </div>
    <script type="module" is:inline>
      // Render Mermaid diagrams client-side. Markdown ```mermaid blocks become
      // <pre><code class="language-mermaid">...</code></pre> — unwrap to <pre class="mermaid">.
      const codes = document.querySelectorAll("code.language-mermaid");
      codes.forEach((code) => {
        const pre = code.parentElement;
        if (pre && pre.tagName === "PRE") {
          const div = document.createElement("pre");
          div.className = "mermaid";
          div.textContent = code.textContent;
          pre.replaceWith(div);
        }
      });
      const diagrams = document.querySelectorAll("pre.mermaid, .mermaid");
      if (diagrams.length) {
        const mod = await import("https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.esm.min.mjs");
        const mermaid = mod.default;
        const isDark = document.documentElement.getAttribute("data-mode") === "dark";
        mermaid.initialize({
          startOnLoad: false,
          theme: isDark ? "dark" : "neutral",
          themeVariables: {
            fontFamily: "JetBrains Mono, monospace",
            fontSize: "13px",
          },
        });
        await mermaid.run({ nodes: diagrams });
      }
    </script>
  </body>
</html>
