---
import Base from "../../layouts/Base.astro";
import { SERIES } from "../../data.js";
import { loadPosts } from "../../lib/posts.js";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const collectionPosts = await getCollection("posts");
  const paths = [];
  for (const s of SERIES) {
    for (const lang of ["en", "ko"]) {
      const url = lang === "ko" ? s.ko : s.en;
      const slug = url.replace(/^\/series\//, "").replace(/\/$/, "");
      const entries = collectionPosts
        .filter((p) => p.data.series === s.slug && p.data.lang === lang)
        .sort((a, b) => (a.data.part ?? 0) - (b.data.part ?? 0));
      paths.push({
        params: { slug },
        props: { series: s, lang, entries },
      });
    }
  }
  return paths;
}

function entryUrl(entry) {
  const d = entry.data.date;
  const y = d.getFullYear();
  const m = String(d.getMonth() + 1).padStart(2, "0");
  const day = String(d.getDate()).padStart(2, "0");
  const base = entry.id.replace(/^\d{4}-\d{2}-\d{2}-/, "").replace(/\.md$/, "");
  return `/${y}/${m}/${day}/${base}/`;
}

const { series, lang, entries } = Astro.props;
const isKo = lang === "ko";
const altLangUrl = isKo ? series.en : series.ko;
const T = isKo
  ? { unit_suffix: " 편 공개", total_suffix: (t) => t ? ` · 총 ${t} 편 예정` : "", back: "← 시리즈", other_lang: "English", all_series: "시리즈 전체", empty: "아직 공개된 에피소드가 없습니다." }
  : { unit_suffix: " posts published", total_suffix: (t) => t ? ` · ${t} planned` : "", back: "← Series", other_lang: "한국어", all_series: "All series", empty: "No episodes published yet." };

// Enrich each entry with excerpt via URL lookup (loader merges
// EXCERPTS map + frontmatter excerpt, so this is single-source).
const allPosts = await loadPosts();
const exByUrl = Object.fromEntries(allPosts.map((p) => [p.url, p.ex]));
const enriched = entries.map((entry) => {
  const url = entryUrl(entry);
  return {
    ...entry,
    _url: url,
    _ex: exByUrl[url] || "",
    _tags: entry.data.tags || [],
  };
});
---
<Base title={`${series.tag} — ${series.title}`} tab="" altLang={altLangUrl} currentLang={lang}>
  <section class="hero" style="padding-bottom:32px; margin-bottom:32px">
    <div class="label">
      <span class="pulse"></span>
      Series · <span data-visible-count>{entries.length}</span>{T.unit_suffix}{T.total_suffix(series.total)}
    </div>
    <h1 style="font-size:48px">
      <em>{series.tag}</em>
      <span style={isKo ? "display:block; font-family:var(--kr); font-size:26px; font-style:normal; color:var(--muted); margin-top:8px; letter-spacing:-0.02em" : "display:block; font-size:26px; font-style:normal; color:var(--muted); margin-top:8px"}>{series.title}</span>
    </h1>
    <p>{series.desc}</p>
    <div style="margin-top:14px; display:flex; gap:14px; font-family:var(--mono); font-size:12px;">
      <a href={altLangUrl} style="color:var(--accent-ink)">{T.other_lang} ↗</a>
    </div>
  </section>

  <section class="block">
    <div class="sec-head">
      <div class="sec-head-l">
        <div class={"title" + (isKo ? " kr" : "")}>{isKo ? "에피소드 목록" : "Episodes"}</div>
        <div class="count"><span data-visible-count>{entries.length}</span>{series.total ? ` / ${series.total}` : ""}</div>
      </div>
    </div>

    <p data-empty-message style={isKo ? "color:var(--muted); display:" + (entries.length === 0 ? "block" : "none") : "color:var(--muted); font-style:italic; display:" + (entries.length === 0 ? "block" : "none")}>{T.empty}</p>
    <div data-post-list style={"display:" + (entries.length === 0 ? "none" : "block")}>
      <div class="post-index">
        <div class="year">2026</div>
        <div>
          {enriched.map((p) => {
            const dateIso = p.data.date.toISOString().slice(0, 10);
            const dateShort = p.data.date.toISOString().slice(5, 10).replace("-", " · ");
            const langUp = p.data.lang.toUpperCase();
            return (
              <a class="post-row" href={p._url} data-lang-post={(p.data.lang || "").toLowerCase()} data-post-date={dateIso}>
                <div>
                  <div class="meta-line">
                    <span class="cat">EP {p.data.part ?? "?"}</span>
                    <span class="d"></span>
                    <span>{dateShort}</span>
                    <span class="d"></span>
                    <span class="lang">{langUp}</span>
                  </div>
                  <h3 class={"title" + (isKo ? " kr" : "")}>{p.data.title}</h3>
                  {p._ex && <p class={"ex" + (isKo ? " kr" : "")}>{p._ex}</p>}
                  {p._tags.length > 0 && (
                    <div class="tags-row">
                      {p._tags.slice(0, 6).map((t) => <span class="tg">#{t}</span>)}
                    </div>
                  )}
                </div>
                <div class={"right" + (isKo ? " kr" : "")}>
                  <span>{isKo ? "읽기" : "read"}</span>
                  <span class="arr">↗</span>
                </div>
              </a>
            );
          })}
        </div>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      const today = new Date().toISOString().slice(0, 10);
      let visible = 0;
      document.querySelectorAll(".post-row[data-post-date]").forEach((el) => {
        if (el.dataset.postDate > today) {
          el.style.display = "none";
        } else {
          visible += 1;
        }
      });
      document.querySelectorAll("[data-visible-count]").forEach((el) => {
        el.textContent = String(visible);
      });
      const emptyMsg = document.querySelector("[data-empty-message]");
      const postList = document.querySelector("[data-post-list]");
      if (visible === 0 && postList && emptyMsg) {
        postList.style.display = "none";
        emptyMsg.style.display = "block";
      }
    })();
  </script>
</Base>
