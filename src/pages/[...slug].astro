---
import { getCollection, render } from "astro:content";
import Base from "../layouts/Base.astro";
import { CATEGORIES, SERIES } from "../data.js";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((post) => {
    const d = post.data.date;
    const y = d.getFullYear();
    const m = String(d.getMonth() + 1).padStart(2, "0");
    const day = String(d.getDate()).padStart(2, "0");
    const base = post.id.replace(/^\d{4}-\d{2}-\d{2}-/, "");
    return {
      params: { slug: `${y}/${m}/${day}/${base}` },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const { Content } = await render(post);
const d = post.data.date;
const dateLabel = d.toISOString().slice(0, 10);
const isKo = post.data.lang === "ko";
const catName = post.data.categories?.[0];
const catEntry = CATEGORIES.find((c) => c.name === catName || c.ko === catName);
const seriesEntry = SERIES.find((s) => s.slug === post.data.series);

// Resolve prev/next posts in the same series + same lang
function entryUrl(entry) {
  const ed = entry.data.date;
  const y = ed.getFullYear();
  const m = String(ed.getMonth() + 1).padStart(2, "0");
  const day = String(ed.getDate()).padStart(2, "0");
  const base = entry.id.replace(/^\d{4}-\d{2}-\d{2}-/, "").replace(/\.md$/, "");
  return `/${y}/${m}/${day}/${base}/`;
}
let nextUrl = null;
let prevUrl = null;
let prevTitle = null;
if (post.data.series && post.data.part) {
  const allPosts = await getCollection("posts");
  if (post.data.next_title && post.data.next_status !== "draft") {
    const next = allPosts.find((p) =>
      p.data.series === post.data.series &&
      p.data.part === post.data.part + 1 &&
      p.data.lang === post.data.lang,
    );
    if (next) nextUrl = entryUrl(next);
  }
  const prev = allPosts.find((p) =>
    p.data.series === post.data.series &&
    p.data.part === post.data.part - 1 &&
    p.data.lang === post.data.lang,
  );
  if (prev) {
    prevUrl = entryUrl(prev);
    prevTitle = prev.data.title;
  }
}

const T = isKo
  ? {
      lang_btn: "EN",
      lang_hint: "English version",
      next_label: "다음 편",
      next_draft: "준비 중",
      series_label: "시리즈",
      ep_of: (p, t) => `에피소드 ${p} / ${t}`,
      prev_label: "이전 편",
      all_categories: "카테고리 전체",
      archives: "아카이브",
      attribution: "Claude Code 의 도움을 받아 작성되었습니다. 아이디어, 경험, 최종 검수는 저자가 직접 수행했습니다.",
      source: "원문",
    }
  : {
      lang_btn: "KO",
      lang_hint: "한국어 버전",
      next_label: "Next in series",
      next_draft: "draft · coming soon",
      series_label: "Series",
      ep_of: (p, t) => `Episode ${p} of ${t}`,
      prev_label: "Previous in series",
      all_categories: "All categories",
      archives: "Archives",
      attribution: "Drafted with Claude Code assistance. Ideas, experience, and final review by the author.",
      source: "Source",
    };
---
<Base title={post.data.title} tab="">
  <article class="post">
    <div class="post-head">
      <div class="meta-line">
        <span>{dateLabel}</span>
        <span class="d"></span>
        {catName && <span class="cat">{catName}</span>}
        <span class="d"></span>
        <span class="lang">{post.data.lang.toUpperCase()}</span>
      </div>
      <h1 class={isKo ? "kr" : ""}>{post.data.title}</h1>
      {post.data.tags && (
        <div class="tags-row">
          {post.data.tags.map((t) => <span class="tg">#{t}</span>)}
        </div>
      )}
      {post.data.alt_lang && (
        <a class="lang-switch" href={post.data.alt_lang} title={T.lang_hint}>
          <span class="code">{T.lang_btn}</span>
          <span class="hint">{T.lang_hint}</span>
          <span class="arr">→</span>
        </a>
      )}
    </div>

    <div class={"post-body" + (isKo ? " kr" : "")}>
      <Content />
    </div>

    <aside class="post-foot">
      {prevUrl && prevTitle && (
        <a class="prev-card" href={prevUrl}>
          <span class="prev-arr">←</span>
          <span class="prev-body">
            <span class="prev-label">{T.prev_label}</span>
            <span class={"prev-title" + (isKo ? " kr" : "")}>{prevTitle}</span>
          </span>
        </a>
      )}

      {post.data.next_title && (
        nextUrl ? (
          <a class="next-card clickable" href={nextUrl}>
            <div class="next-label">
              <span class="pulse"></span>
              {T.next_label}
            </div>
            <h3 class={isKo ? "kr" : ""}>{post.data.next_title}</h3>
            {post.data.next_desc && <p class={isKo ? "kr" : ""}>{post.data.next_desc}</p>}
            <span class="next-arr">→</span>
          </a>
        ) : (
          <div class="next-card">
            <div class="next-label">
              <span class="pulse"></span>
              {T.next_label}
              {post.data.next_status === "draft" && <span class="draft-tag">{T.next_draft}</span>}
            </div>
            <h3 class={isKo ? "kr" : ""}>{post.data.next_title}</h3>
            {post.data.next_desc && <p class={isKo ? "kr" : ""}>{post.data.next_desc}</p>}
          </div>
        )
      )}

      <div class="foot-meta">
        {seriesEntry && (
          <div class="foot-row">
            <span class="k">{T.series_label}</span>
            <a href={isKo ? seriesEntry.ko : seriesEntry.en}>
              [{seriesEntry.tag}] {T.ep_of(post.data.part ?? seriesEntry.ep, seriesEntry.total)}
              <span class="arr">↗</span>
            </a>
          </div>
        )}
        {catEntry && (
          <div class="foot-row">
            <span class="k">{isKo ? "카테고리" : "Category"}</span>
            <a href={`/categories/${catEntry.slug}/`}>
              {catEntry.name} · {catEntry.ko}
              <span class="arr">↗</span>
            </a>
          </div>
        )}
        {post.data.source_url && (
          <div class="foot-row">
            <span class="k">{T.source}</span>
            <a href={post.data.source_url} rel="noopener">
              {post.data.source_label || post.data.source_url}
              <span class="arr">↗</span>
            </a>
          </div>
        )}
      </div>

      <p class={"attribution" + (isKo ? " kr" : "")}>{T.attribution}</p>

      <nav class="foot-nav">
        <a href="/archives/">← {T.archives}</a>
        <a href="/categories/">{T.all_categories} →</a>
      </nav>
    </aside>
  </article>
</Base>

<style is:global>
  .post { max-width: 720px; }
  .post-head { padding-bottom: 28px; margin-bottom: 32px; border-bottom: 1px solid var(--hair); }
  .post-head .meta-line {
    font-family: var(--mono); font-size: 10.5px;
    color: var(--muted); letter-spacing: 0.06em;
    text-transform: uppercase;
    display: flex; align-items: center; gap: 8px;
    margin-bottom: 18px;
  }
  .post-head .meta-line .d {
    width: 3px; height: 3px; background: var(--muted-2); border-radius: 50%;
  }
  .post-head .meta-line .lang {
    padding: 1px 6px; border: 1px solid var(--hair); border-radius: 3px;
  }
  .post-head h1 {
    font-family: var(--display);
    font-weight: 400; font-size: 44px; line-height: 1.08;
    letter-spacing: -0.02em;
    margin: 0 0 18px;
    color: var(--ink);
  }
  .post-head h1.kr { font-family: var(--kr); font-weight: 600; letter-spacing: -0.025em; }
  .post-head .tags-row { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 18px; }
  .post-head .tg {
    font-family: var(--mono); font-size: 10.5px;
    color: var(--muted); padding: 2px 8px;
    border: 1px solid var(--hair); border-radius: 3px;
  }

  /* Language switch button */
  .lang-switch {
    display: inline-flex; align-items: center; gap: 10px;
    margin-top: 4px;
    padding: 9px 14px;
    background: var(--accent-soft);
    border: 1px solid color-mix(in oklab, var(--accent) 25%, transparent);
    border-radius: 8px;
    font-family: var(--mono); font-size: 11.5px;
    color: var(--accent-ink);
    letter-spacing: 0.04em;
    transition: background .12s, transform .12s;
  }
  .lang-switch:hover {
    background: color-mix(in oklab, var(--accent) 18%, var(--bg));
    transform: translateY(-1px);
  }
  .lang-switch .code {
    font-weight: 600; letter-spacing: 0.08em;
    padding: 2px 6px;
    background: var(--bg);
    border-radius: 3px;
    color: var(--accent-ink);
  }
  .lang-switch .hint { color: var(--accent-ink); opacity: 0.85; }
  .lang-switch .arr { color: var(--accent); }

  /* Body */
  .post-body { font-size: 16px; line-height: 1.75; color: var(--ink-2); }
  .post-body.kr { font-family: var(--kr); font-size: 15.5px; letter-spacing: -0.005em; line-height: 1.8; }
  .post-body h2 {
    font-family: var(--display); font-weight: 400;
    font-size: 28px; letter-spacing: -0.015em;
    margin: 48px 0 16px; color: var(--ink);
  }
  .post-body.kr h2 { font-family: var(--kr); font-weight: 600; font-size: 24px; letter-spacing: -0.02em; }
  .post-body h3 {
    font-family: var(--display); font-weight: 400;
    font-size: 22px; letter-spacing: -0.01em;
    margin: 32px 0 12px; color: var(--ink);
  }
  .post-body.kr h3 { font-family: var(--kr); font-weight: 600; font-size: 19px; }
  .post-body p { margin: 0 0 18px; }
  .post-body a { color: var(--accent-ink); text-decoration: underline; text-underline-offset: 3px; }
  .post-body code {
    font-family: var(--mono); font-size: 13px;
    background: var(--bg-2); padding: 1px 5px; border-radius: 3px;
  }
  .post-body pre {
    font-family: var(--mono); font-size: 13px;
    background: var(--surface); border: 1px solid var(--hair); border-radius: 8px;
    padding: 16px 20px; overflow-x: auto;
    line-height: 1.5;
  }
  .post-body pre code { background: transparent; padding: 0; }
  .post-body blockquote {
    margin: 24px 0;
    padding: 4px 20px;
    border-left: 3px solid var(--accent);
    color: var(--ink-2);
  }
  .post-body blockquote p { margin: 0 0 10px; }
  .post-body blockquote p:last-child { margin-bottom: 0; }
  .post-body blockquote strong { color: var(--ink); }
  .post-body ul, .post-body ol { margin: 0 0 18px; padding-left: 24px; }
  .post-body li { margin-bottom: 6px; }
  .post-body hr { border: 0; border-top: 1px solid var(--hair); margin: 36px 0; }

  /* Tables */
  .post-body table {
    width: 100%;
    margin: 28px 0;
    border-collapse: collapse;
    font-size: 13.5px;
    line-height: 1.55;
    display: block;
    overflow-x: auto;
    border: 1px solid var(--hair);
    border-radius: 8px;
  }
  .post-body table thead {
    background: var(--bg-2);
  }
  .post-body table th {
    text-align: left;
    font-family: var(--mono);
    font-size: 10.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: 500;
    color: var(--ink);
    padding: 12px 14px;
    border-bottom: 1px solid var(--hair);
    white-space: nowrap;
    vertical-align: middle;
  }
  .post-body table td {
    padding: 12px 14px;
    border-bottom: 1px solid var(--hair-2);
    color: var(--ink-2);
    vertical-align: top;
  }
  .post-body table tr:last-child td {
    border-bottom: 0;
  }
  .post-body table tr:hover td {
    background: var(--hair-2);
  }
  .post-body.kr table { font-family: var(--kr); font-size: 13px; letter-spacing: -0.005em; }
  .post-body.kr table th { font-family: var(--mono); }
  .post-body table code {
    font-size: 12px;
    background: var(--hair-2);
    padding: 1px 5px;
    border-radius: 3px;
  }
  .post-body table strong { color: var(--ink); font-weight: 500; }

  /* KaTeX math blocks */
  .post-body .katex-display {
    margin: 24px 0;
    padding: 20px;
    background: var(--surface);
    border: 1px solid var(--hair);
    border-radius: 8px;
    overflow-x: auto;
  }
  .post-body .katex { font-size: 1.05em; }

  /* Mermaid diagrams */
  .post-body pre.mermaid {
    background: var(--surface);
    border: 1px solid var(--hair);
    border-radius: 8px;
    padding: 24px;
    margin: 28px 0;
    text-align: center;
    overflow-x: auto;
  }
  .post-body pre.mermaid svg {
    max-width: 100%;
    height: auto;
  }

  /* Footer card */
  .post-foot {
    margin-top: 56px;
    padding-top: 40px;
    border-top: 1px solid var(--hair);
    display: flex; flex-direction: column; gap: 24px;
  }
  .prev-card {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 14px 20px;
    border: 1px solid var(--hair);
    border-radius: 8px;
    color: inherit;
    text-decoration: none;
    transition: border-color .15s, transform .15s, background .15s;
  }
  .prev-card:hover {
    border-color: var(--accent);
    transform: translateX(-2px);
    background: var(--hair-2);
  }
  .prev-card .prev-arr {
    font-family: var(--mono); font-size: 18px;
    color: var(--muted-2);
    transition: color .15s;
  }
  .prev-card:hover .prev-arr { color: var(--accent); }
  .prev-card .prev-body {
    display: flex; flex-direction: column; gap: 3px;
    min-width: 0;
  }
  .prev-card .prev-label {
    font-family: var(--mono); font-size: 10px;
    letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--muted);
  }
  .prev-card .prev-title {
    font-size: 14px; line-height: 1.35;
    color: var(--ink-2);
    letter-spacing: -0.005em;
  }
  .prev-card .prev-title.kr { font-family: var(--kr); font-size: 14px; letter-spacing: -0.015em; }

  .next-card {
    display: block;
    padding: 22px 24px;
    background: var(--surface);
    border: 1px solid var(--hair);
    border-radius: 10px;
    position: relative;
    color: inherit;
    text-decoration: none;
  }
  .next-card.clickable {
    transition: border-color .15s, transform .15s, box-shadow .15s;
  }
  .next-card.clickable:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(20,20,20,0.06);
  }
  .next-card.clickable:hover .next-arr {
    color: var(--accent);
    transform: translateX(4px);
  }
  .next-card .next-arr {
    position: absolute;
    right: 24px; top: 22px;
    font-family: var(--mono); font-size: 18px;
    color: var(--muted-2);
    transition: color .15s, transform .15s;
  }
  .next-card .next-label {
    display: inline-flex; align-items: center; gap: 10px;
    font-family: var(--mono); font-size: 10px;
    color: var(--muted); letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .next-card .next-label .pulse {
    width: 6px; height: 6px; background: var(--accent); border-radius: 50%;
    box-shadow: 0 0 0 3px var(--accent-soft);
  }
  .next-card .draft-tag {
    padding: 2px 8px;
    background: var(--hair-2);
    border-radius: 3px;
    color: var(--muted-2);
    letter-spacing: 0.08em;
    font-size: 9.5px;
  }
  .next-card h3 {
    font-family: var(--display); font-weight: 400;
    font-size: 22px; letter-spacing: -0.01em;
    line-height: 1.25;
    margin: 0 0 8px; color: var(--ink);
  }
  .next-card h3.kr { font-family: var(--kr); font-weight: 600; font-size: 19px; letter-spacing: -0.02em; }
  .next-card p {
    font-size: 14px; line-height: 1.6;
    color: var(--ink-2); margin: 0;
    max-width: 560px;
  }
  .next-card p.kr { font-family: var(--kr); font-size: 13.5px; letter-spacing: -0.005em; line-height: 1.7; }

  .foot-meta {
    display: flex; flex-direction: column; gap: 1px;
  }
  .foot-meta .foot-row {
    display: flex; align-items: center; gap: 14px;
    padding: 10px 0;
    border-bottom: 1px solid var(--hair-2);
    font-family: var(--mono); font-size: 11.5px;
  }
  .foot-meta .foot-row:last-child { border-bottom: 0; }
  .foot-meta .foot-row .k {
    display: inline-block;
    min-width: 70px;
    color: var(--muted-2);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 10px;
  }
  .foot-meta .foot-row a {
    color: var(--ink-2);
    display: inline-flex; align-items: center; gap: 6px;
    text-decoration: none;
    transition: color .12s;
  }
  .foot-meta .foot-row a:hover { color: var(--accent-ink); }
  .foot-meta .foot-row .arr { color: var(--muted-2); }
  .foot-meta .foot-row a:hover .arr { color: var(--accent); }

  .attribution {
    font-size: 12px; line-height: 1.6;
    color: var(--muted);
    padding: 16px 0;
    margin: 0;
    border-top: 1px solid var(--hair-2);
    border-bottom: 1px solid var(--hair-2);
    max-width: 620px;
  }
  .attribution.kr { font-family: var(--kr); font-size: 12.5px; letter-spacing: -0.005em; }

  .foot-nav {
    display: flex; justify-content: space-between;
    font-family: var(--mono); font-size: 11px;
    color: var(--muted);
    letter-spacing: 0.04em;
  }
  .foot-nav a { transition: color .12s; }
  .foot-nav a:hover { color: var(--ink); }
</style>
