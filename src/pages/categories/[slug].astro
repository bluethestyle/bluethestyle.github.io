---
import Base from "../../layouts/Base.astro";
import { CATEGORIES } from "../../data.js";
import { loadPosts } from "../../lib/posts.js";

export async function getStaticPaths() {
  const allPosts = await loadPosts();
  return CATEGORIES.filter((c) => c.count > 0).map((c) => {
    const posts = allPosts
      .filter((p) => !p.draft && (p.cat === c.name || p.cat === c.ko))
      .sort((a, b) => b.date.localeCompare(a.date));
    return { params: { slug: c.slug }, props: { cat: c, posts } };
  });
}

const { cat, posts } = Astro.props;
const cvar = `var(--c${cat.color})`;
const cs = `var(--c${cat.color}s)`;
---
<Base title={`${cat.name} — bluethestyle`} tab="categories">
  <section class="hero" style="padding-bottom:32px; margin-bottom:32px">
    <div class="label">
      <span class="pulse" style={`background:${cvar};box-shadow:0 0 0 3px ${cs}`}></span>
      <span data-lang-ui="en">Category · <span data-visible-count>{posts.length}</span> <span data-post-word>post{posts.length === 1 ? "" : "s"}</span></span>
      <span data-lang-ui="ko">카테고리 · 글 <span data-visible-count>{posts.length}</span>개</span>
    </div>
    <h1 data-lang-ui="en" style="font-size:52px">
      <em>{cat.name}</em>
      <span style="display:block; font-family:var(--kr); font-size:28px; font-style:normal; color:var(--muted); margin-top:8px; letter-spacing:-0.02em">{cat.ko}</span>
    </h1>
    <h1 data-lang-ui="ko" class="kr" style="font-size:52px">
      <em>{cat.ko}</em>
      <span style="display:block; font-family:var(--mono); font-style:italic; font-size:24px; color:var(--muted); margin-top:8px; letter-spacing:-0.02em">{cat.name}</span>
    </h1>
    <p>{cat.desc}</p>
    <div style="margin-top:14px">
      <a href="/categories/" style="font-family:var(--mono); font-size:12px; color:var(--muted);" data-i18n-ko="← 전체 카테고리">← all categories</a>
    </div>
  </section>

  <section class="block">
    <div class="sec-head">
      <div class="sec-head-l">
        <div class="title" data-lang-ui="en">Posts in <em>{cat.name}</em></div>
        <div class="title kr" data-lang-ui="ko"><em>{cat.ko}</em>의 글</div>
        <div class="count"><span data-visible-count>{posts.length}</span> <span data-i18n-ko="게시됨">published</span></div>
      </div>
    </div>

    <div class="post-index">
      <div class="year">2026</div>
      <div>
        {posts.map((p) => {
          const isKo = p.lang === "KO";
          return (
            <a class="post-row" href={p.url} data-lang-post={(p.lang||"").toLowerCase()} data-post-date={p.date}>
              <div>
                <div class="meta-line">
                  <span>{p.date.slice(5).replace("-", " · ")}</span>
                  <span class="d"></span>
                  <span class="cat">{p.cat}</span>
                  <span class="d"></span>
                  <span class="lang">{p.lang}</span>
                </div>
                <h3 class={"title" + (isKo ? " kr" : "")}>{p.title}</h3>
                <p class={"ex" + (isKo ? " kr" : "")}>{p.ex}</p>
                <div class="tags-row">
                  {p.tags.map((t) => <span class="tg">#{t}</span>)}
                </div>
              </div>
              <div class="right">
                <span data-i18n-ko="읽기">read</span>
                <span class="arr">↗</span>
              </div>
            </a>
          );
        })}
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      const today = new Date().toISOString().slice(0, 10);
      let visible = 0;
      document.querySelectorAll(".post-row[data-post-date]").forEach((el) => {
        if (el.dataset.postDate > today) {
          el.style.display = "none";
        } else {
          visible += 1;
        }
      });
      document.querySelectorAll("[data-visible-count]").forEach((el) => {
        el.textContent = String(visible);
      });
      document.querySelectorAll("[data-post-word]").forEach((el) => {
        el.textContent = visible === 1 ? "post" : "posts";
      });
    })();
  </script>
</Base>
